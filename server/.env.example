# ============================================================
# OPHTHALMO-AI SERVER — Environment Variables
# Salin file ini menjadi .env dan isi nilainya.
# JANGAN commit file .env ke git!
# ============================================================

# === WAJIB ===

# API key Claude dari console.anthropic.com
# Format: sk-ant-api03-...
ANTHROPIC_API_KEY=sk-ant-...

# Firebase Project ID (dari firebase-config.js, field projectId)
FIREBASE_PROJECT_ID=project-anda

# === OPSIONAL ===

# URL endpoint model ML Vision dari Google Colab (via ngrok).
# Kosongkan jika ingin pakai mock deterministik (default).
# Format: https://xxxx.ngrok-free.app/predict
VISION_ENDPOINT=

# Port server (Railway/Render auto-set ini, tidak perlu diubah)
PORT=3000
